model LandingPage {
  id                 String            @id @default(cuid())
  advertiserId       String            @map("advertiser_id")
  campaignId         String?           @map("campaign_id")
  slug               String            @unique
  name               String
  status             LandingPageStatus @default(DRAFT)
  craftState         Json              @map("craft_state")
  themeJson          Json              @default("{}") @map("theme_json")
  formJson           Json?             @map("form_json")
  publishedVersionId String?           @unique @map("published_version_id")
  autosaveAt         DateTime?         @map("autosave_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  advertiser       User                 @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  campaign         Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  versions         LandingPageVersion[] @relation("PageVersions")
  publishedVersion LandingPageVersion?  @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  assets           LandingPageAsset[]

  @@index([advertiserId])
  @@index([campaignId])
  @@index([status])
  @@map("landing_pages")
}

model LandingPageVersion {
  id            String   @id @default(cuid())
  landingPageId String   @map("landing_page_id")
  versionNumber Int      @map("version_number")
