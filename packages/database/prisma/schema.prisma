  craftState    Json     @map("craft_state")
  themeJson     Json     @map("theme_json")
  formJson      Json?    @map("form_json")
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  landingPage  LandingPage  @relation("PageVersions", fields: [landingPageId], references: [id], onDelete: Cascade)
  publishedFor LandingPage? @relation("PublishedVersion")

  @@unique([landingPageId, versionNumber])
  @@index([landingPageId])
  @@map("landing_page_versions")
}

model PageTemplate {
