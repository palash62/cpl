{
  "name": "cpl",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cpl/platform & npm run dev --workspace @cpl/tracking",
    "dev:platform": "npm run dev --workspace @cpl/platform",
    "dev:tracking": "npm run dev --workspace @cpl/tracking",
    "build": "npm run build --workspace @cpl/platform && npm run build --workspace @cpl/tracking",
    "build:platform": "NODE_OPTIONS='--max-old-space-size=2048' npm run build --workspace @cpl/platform",
    "build:tracking": "NODE_OPTIONS='--max-old-space-size=1024' npm run build --workspace @cpl/tracking",
    "start": "npm run start --workspace @cpl/platform & npm run start --workspace @cpl/tracking",
    "start:4gb": "bash deploy/run-4gb.sh",
    "start:domains": "bash deploy/run-domains.sh",
    "start:ports": "bash deploy/start-open-ports.sh",
    "lint": "npm run lint --workspace @cpl/platform && npm run lint --workspace @cpl/tracking",
    "typecheck": "npm run typecheck --workspace @cpl/platform && npm run typecheck --workspace @cpl/tracking",
    "test": "npm run test --workspace @cpl/platform",
    "db:push": "npm run db:push --workspace @cpl/database",
    "db:seed": "npm run db:seed --workspace @cpl/database",
    "db:studio": "npm run db:studio --workspace @cpl/database",
    "worker:email": "npm run worker:email --workspace @cpl/platform",
    "test:smoke": "tsx scripts/smoke-deploy.ts",
    "test:emails": "npm run test:emails --workspace @cpl/platform",
    "build:production": "bash deploy/build-production.sh",
    "deploy:env": "bash deploy/env-production.sh",
    "deploy:push": "bash deploy/push-to-server.sh",
    "postinstall": "npm run generate --workspace @cpl/database"
  },
  "devDependencies": {
    "csstype": "^3.2.3"
  },
  "dependencies": {
    "immer": "^11.1.11",
    "preact-render-to-string": "^6.7.0",
    "react-redux": "^9.3.0"
  }
}
