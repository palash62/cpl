# Copy to deploy/docker-registry.env on the server (gitignored).
# Used by docker-run.sh / docker-push.sh.

# GitHub user or org that owns the GHCR packages
GHCR_OWNER=palash62

# Image tag (usually latest; CI also pushes git SHA tags)
IMAGE_TAG=latest

# Full image refs (override only if you use a fork / other registry)
# CPL_PLATFORM_IMAGE=ghcr.io/palash62/cpl-platform:latest
# CPL_TRACKING_IMAGE=ghcr.io/palash62/cpl-tracking:latest
