generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ADVERTISER
  PUBLISHER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignCategory {
  FINANCE
  INSURANCE
  EDUCATION
  REAL_ESTATE
  GENERIC
}

enum PublisherAccess {
  OPEN
  APPROVAL_REQUIRED
  INVITE_ONLY
}

enum PublisherCampaignStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadStatus {
  CAPTURED
  VALIDATING
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum DepositStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutStatus {
  PENDING
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum PayoutMethod {
  PAYPAL
  BANK_TRANSFER
  STRIPE_CONNECT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  GENERAL
  BILLING
  TECHNICAL
  CAMPAIGN
  PAYOUT
  OTHER
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  name          String
  role          UserRole
  status        UserStatus @default(PENDING)
  emailVerified DateTime?  @map("email_verified")
  referralCode  String?    @unique @map("referral_code")
  referredById  String?    @map("referred_by_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  referredBy        User?  @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         User[] @relation("UserReferrals")
  advertiserProfile AdvertiserProfile?
  publisherProfile  PublisherProfile?
  wallet            Wallet?
  campaigns         Campaign[]           @relation("AdvertiserCampaigns")
  leads             Lead[]               @relation("PublisherLeads")
  publisherCampaigns PublisherCampaign[]
  trackingLinks     TrackingLink[]
  publisherSmartLink PublisherSmartLink?
  advertiserPublisherBlocks AdvertiserPublisherBlock[] @relation("AdvertiserBlocks")
  blockedByAdvertisers    AdvertiserPublisherBlock[] @relation("PublisherBlocks")
  payouts           Payout[]
  deposits          Deposit[]
  notifications     Notification[]
  supportTickets    SupportTicket[]      @relation("TicketOwner")
  assignedTickets   SupportTicket[]      @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  auditLogs         AuditLog[]
  leadStatusChanges LeadStatusHistory[]

  @@index([role])
  @@index([status])
  @@index([referredById])
  @@map("users")
}

model AdvertiserProfile {
  id          String  @id @default(cuid())
  userId      String  @unique @map("user_id")
  company     String
  industry    String?
  billingInfo Json?   @map("billing_info")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("advertiser_profiles")
}

model PublisherProfile {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  website       String?
  trafficSource String?   @map("traffic_source")
  country       String?
  addressLine1  String?   @map("address_line_1")
  addressLine2  String?   @map("address_line_2")
  city          String?
  state         String?
  postalCode    String?   @map("postal_code")
  rejectionReason String? @map("rejection_reason")
  rejectedAt    DateTime? @map("rejected_at")
  kycStatus     KycStatus @default(NOT_SUBMITTED) @map("kyc_status")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("publisher_profiles")
}

model Campaign {
  id              String           @id @default(cuid())
  advertiserId    String           @map("advertiser_id")
  name            String
  description     String?
  category        CampaignCategory @default(GENERIC)
  cpl             Decimal          @db.Decimal(10, 2)
  budget          Decimal          @db.Decimal(12, 2)
  spent           Decimal          @default(0) @db.Decimal(12, 2)
  dailyCap        Int?             @map("daily_cap")
  monthlyCap      Int?             @map("monthly_cap")
  status          CampaignStatus   @default(DRAFT)
  publisherAccess PublisherAccess  @default(APPROVAL_REQUIRED) @map("publisher_access")
  autoApprove     Boolean          @default(false) @map("auto_approve")
  targeting       Json             @default("{}")
  pixelToken      String?          @unique @map("pixel_token")
  rejectionReason String?          @map("rejection_reason")
  rejectedAt      DateTime?        @map("rejected_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  advertiser         User                @relation("AdvertiserCampaigns", fields: [advertiserId], references: [id])
  fields             CampaignField[]
  publisherCampaigns PublisherCampaign[]
  trackingLinks      TrackingLink[]
  leads              Lead[]
  pixelEvents        PixelEvent[]

  @@index([advertiserId])
  @@index([status])
  @@index([category])
  @@map("campaigns")
}

model CampaignField {
  id              String  @id @default(cuid())
  campaignId      String  @map("campaign_id")
  fieldName       String  @map("field_name")
  label           String
  fieldType       String  @map("field_type")
  required        Boolean @default(true)
  validationRules Json?   @map("validation_rules")
  sortOrder       Int     @default(0) @map("sort_order")
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_fields")
}

model PublisherCampaign {
  id          String                  @id @default(cuid())
  publisherId String                  @map("publisher_id")
  campaignId  String                  @map("campaign_id")
  status      PublisherCampaignStatus @default(PENDING)
  approvedAt  DateTime?               @map("approved_at")
  publisher   User                    @relation(fields: [publisherId], references: [id])
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([publisherId, campaignId])
  @@map("publisher_campaigns")
}

model TrackingLink {
  id          String   @id @default(cuid())
  publisherId String   @map("publisher_id")
  campaignId  String   @map("campaign_id")
  slug        String   @unique
  clickCount  Int      @default(0) @map("click_count")
  createdAt   DateTime @default(now()) @map("created_at")

  publisher User     @relation(fields: [publisherId], references: [id])
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clicks    Click[]
  leads     Lead[]

  @@index([publisherId, campaignId])
  @@map("tracking_links")
}

model PixelEvent {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  leadId     String?  @map("lead_id")
  txnId      String?  @map("txn_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([leadId])
  @@index([createdAt])
  @@map("pixel_events")
}

model PublisherSmartLink {
  id             String   @id @default(cuid())
  publisherId    String   @unique @map("publisher_id")
  slug           String   @unique
  rotationCursor Int      @default(0) @map("rotation_cursor")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  publisher User @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@map("publisher_smart_links")
}

model AdvertiserPublisherBlock {
  id           String   @id @default(cuid())
  advertiserId String   @map("advertiser_id")
  publisherId  String   @map("publisher_id")
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at")

  advertiser User @relation("AdvertiserBlocks", fields: [advertiserId], references: [id], onDelete: Cascade)
  publisher  User @relation("PublisherBlocks", fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([advertiserId, publisherId])
  @@index([publisherId])
  @@map("advertiser_publisher_blocks")
}

model Click {
  id             String   @id @default(cuid())
  trackingLinkId String   @map("tracking_link_id")
  ip             String
  userAgent      String?  @map("user_agent")
  referrer       String?
  source         String?
  subId          String?  @map("sub_id")
  geo            Json?
  createdAt      DateTime @default(now()) @map("created_at")

  trackingLink TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)

  @@index([trackingLinkId])
  @@index([createdAt])
  @@map("clicks")
}

model Lead {
  id             String     @id @default(cuid())
  campaignId     String     @map("campaign_id")
  publisherId    String     @map("publisher_id")
  trackingLinkId String?    @map("tracking_link_id")
  status         LeadStatus @default(CAPTURED)
  data           Json
  score          Int?
  ip             String?
  userAgent      String?    @map("user_agent")
  country        String?
  source         String?
  subId          String?    @map("sub_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  campaign          Campaign               @relation(fields: [campaignId], references: [id])
  publisher         User                   @relation("PublisherLeads", fields: [publisherId], references: [id])
  trackingLink      TrackingLink?          @relation(fields: [trackingLinkId], references: [id])
  statusHistory     LeadStatusHistory[]
  validationResults LeadValidationResult[]
  platformFee       PlatformFee?
  pixelEvents       PixelEvent[]

  @@index([campaignId])
  @@index([publisherId])
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model LeadStatusHistory {
  id         String      @id @default(cuid())
  leadId     String      @map("lead_id")
  fromStatus LeadStatus? @map("from_status")
  toStatus   LeadStatus  @map("to_status")
  actorId    String?     @map("actor_id")
  reason     String?
  createdAt  DateTime    @default(now()) @map("created_at")

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@map("lead_status_history")
}

model LeadValidationResult {
  id      String  @id @default(cuid())
  leadId  String  @map("lead_id")
  rule    String
  passed  Boolean
  details String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_validation_results")
}

model Wallet {
  id           String  @id @default(cuid())
  userId       String  @unique @map("user_id")
  balance      Decimal @default(0) @db.Decimal(12, 2)
  holdBalance  Decimal @default(0) @db.Decimal(12, 2) @map("hold_balance")
  currency     String  @default("USD")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries LedgerEntry[]

  @@map("wallets")
}

model LedgerEntry {
  id            String          @id @default(cuid())
  walletId      String          @map("wallet_id")
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2) @map("balance_after")
  referenceType String          @map("reference_type")
  referenceId   String?         @map("reference_id")
  description   String?
  createdAt     DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("ledger_entries")
}

model Deposit {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  amount          Decimal       @db.Decimal(12, 2)
  stripePaymentId String?       @map("stripe_payment_id")
  status          DepositStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("deposits")
}

model Payout {
  id              String       @id @default(cuid())
  publisherId     String       @map("publisher_id")
  amount          Decimal      @db.Decimal(12, 2)
  method          PayoutMethod
  status          PayoutStatus @default(PENDING)
  rejectionReason String?      @map("rejection_reason")
  rejectedAt      DateTime?    @map("rejected_at")
  idempotencyKey  String?      @unique @map("idempotency_key")
  processedAt     DateTime?    @map("processed_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  publisher User @relation(fields: [publisherId], references: [id])

  @@map("payouts")
}

model PlatformFee {
  id          String  @id @default(cuid())
  leadId      String  @unique @map("lead_id")
  feeAmount   Decimal @db.Decimal(10, 2) @map("fee_amount")
  feePercent  Decimal @db.Decimal(5, 2) @map("fee_percent")
  lead        Lead    @relation(fields: [leadId], references: [id])

  @@map("platform_fees")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model SupportTicket {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  subject    String
  category   TicketCategory
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(MEDIUM)
  assignedTo String?        @map("assigned_to")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user     User            @relation("TicketOwner", fields: [userId], references: [id])
  assignee User?           @relation("TicketAssignee", fields: [assignedTo], references: [id])
  messages TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  senderId    String   @map("sender_id")
  body        String
  isInternal  Boolean  @default(false) @map("is_internal")
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@map("ticket_messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("platform_settings")
}

model IpBlocklist {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ip_blocklist")
}
