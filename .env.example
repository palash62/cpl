# Shared
DATABASE_URL="mysql://root:password@localhost:3306/cpl"
INTERNAL_SERVICE_TOKEN="change-me-to-a-random-64-char-secret"

# Platform (leadvix.io) — apps/platform/.env
AUTH_SECRET="your-secret-key-min-32-characters"
AUTH_URL="https://leadvix.io"
APP_URL="https://leadvix.io"
PLATFORM_URL="https://leadvix.io"
TRACKING_URL="https://leadgenlink.site"
NEXT_PUBLIC_PLATFORM_URL="https://leadvix.io"
NEXT_PUBLIC_TRACKING_URL="https://leadgenlink.site"
PORT=3000
# Tawk.to live chat (platform-wide). Set empty to disable.
NEXT_PUBLIC_TAWK_TO_PROPERTY_PATH=6a5c7630aa83a11d48ca4b80/1jtsirc0m

# Tracking (leadgenlink.site) — apps/tracking/.env
TRACKING_URL="http://leadgenlink.site"
PLATFORM_URL="http://leadvix.io"
NEXT_PUBLIC_TRACKING_URL="http://leadgenlink.site"
NEXT_PUBLIC_PLATFORM_URL="http://leadvix.io"

# Optional fraud geo lookup for smart link rotation
FRAUD_IP_API_KEY=

# Email, payments, etc. (platform only)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
REDIS_URL="redis://localhost:6379"
SENTRY_DSN=""
# Transactional email — Mailgun (preferred) or SMTP fallback
# Mailgun HTTP API (Sending key from Mailgun dashboard)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.leadvix.io
MAILGUN_FROM="Leadvix <noreply@mg.leadvix.io>"
MAILGUN_API_BASE=https://api.mailgun.net
# Mailgun SMTP (username + password from Mailgun dashboard — used if API fails or unset)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@mg.leadvix.io
SMTP_PASS=
SMTP_FROM="Leadvix <noreply@mg.leadvix.io>"
ADMIN_ALERT_EMAIL=admin@leadvix.io
SUPPORT_EMAIL=support@leadvix.io
# EmailListVerify API key (apps.emaillistverify.com) — lead fraud email validation
FRAUD_EMAIL_API_KEY=
INTEGRATION_ENCRYPTION_KEY=
# CPA Offer Marketplace — demo gate (unset = advertiser@cpl.local only; * = all advertisers)
CPA_OFFERS_ADVERTISER_ALLOWLIST=advertiser@cpl.local
# Marketing email (SES) — separate from transactional Mailgun
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_DOMAIN=leadvix.io
SES_FROM_EMAIL=noreply@leadvix.io
SES_CONFIGURATION_SET=
SES_WEBHOOK_SECRET=YOUR_RANDOM_WEBHOOK_SECRET
