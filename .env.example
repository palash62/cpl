AUTH_SECRET="your-secret-key-min-32-characters"
AUTH_URL="http://localhost:3000"
DATABASE_URL="mysql://root:password@localhost:3306/cpl"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
REDIS_URL="redis://localhost:6379"
SENTRY_DSN=""

# SMTP email (optional — can also be configured in Admin → Settings → Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CPL Platform <noreply@yourdomain.com>"
ADMIN_ALERT_EMAIL=admin@yourdomain.com
APP_URL=http://localhost:3000

# Optional fraud detection APIs (built-in rules run without these)
FRAUD_IP_API_KEY=
FRAUD_EMAIL_API_KEY=

# Encrypt publisher integration secrets at rest (optional — falls back to AUTH_SECRET)
INTEGRATION_ENCRYPTION_KEY=

# AWS SES (marketing email — can also be configured in Admin → Settings → SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_DOMAIN=
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=
SES_WEBHOOK_SECRET=
